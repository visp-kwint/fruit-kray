generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("") @map("name")
  passwordHash String   @map("password_hash")
  role         String   @default("USER")
  lastAddress  String   @default("") @map("last_address")
  lastLat      Float    @default(0) @map("last_lat")
  lastLng      Float    @default(0) @map("last_lng")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders          Order[]
  reviews         Review[]
  deliveryReviews DeliveryReview[]
  cartItems       CartItem[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  details     String   @default("")
  price       Float
  imageUrl    String   @default("") @map("image_url")
  categoryId  String   @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  isNew      Boolean  @default(false) @map("is_new")
  isDiscount Boolean  @default(false) @map("is_discount")
  isPopular  Boolean  @default(false) @map("is_popular")
  isDayItem  Boolean  @default(false) @map("is_day_item")
  stock      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orderItems      OrderItem[]
  adModalsTrigger AdModal[]   @relation("AdModalTrigger")
  adModalsProduct AdModal[]   @relation("AdModalProduct")
  reviews         Review[]
  cartItems       CartItem[]

  @@map("products")
}

model Order {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  totalPrice      Float    @map("total_price")
  status          String   @default("PENDING")
  deliveryAddress String   @map("delivery_address")
  deliveryLat     Float    @default(0) @map("delivery_lat")
  deliveryLng     Float    @default(0) @map("delivery_lng")
  deliveryMinutes Int      @map("delivery_minutes")
  createdAt       DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  reviews        Review[]
  deliveryReview DeliveryReview?

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  name      String
  price     Float
  quantity  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model AdModal {
  id               String   @id @default(cuid())
  triggerProductId String   @map("trigger_product_id")
  title            String
  description      String   @default("")
  productId        String   @map("product_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  triggerProduct Product @relation("AdModalTrigger", fields: [triggerProductId], references: [id], onDelete: Cascade)
  product        Product @relation("AdModalProduct", fields: [productId], references: [id], onDelete: Cascade)

  @@map("ad_modals")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  orderId   String   @map("order_id")
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId], name: "user_product_order_unique")
  @@map("reviews")
}

model DeliveryReview {
  id        String   @id @default(cuid())
  orderId   String   @unique @map("order_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("delivery_reviews")
}

model CartItem {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  productId    String   @map("product_id")
  name         String
  price        Float
  quantity     Int
  imageUrl     String   @default("") @map("image_url")
  categoryName String   @default("") @map("category_name")
  categorySlug String   @default("") @map("category_slug")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

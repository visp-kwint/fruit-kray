.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  height: 72px;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid transparent;
  transition: all 0.22s ease;
}

.header.scrolled {
  border-bottom-color: var(--cherry-border);
  box-shadow: 0 2px 20px rgba(139, 26, 46, 0.08);
}

.inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  flex-shrink: 0;
}

.logoIcon {
  color: var(--cherry);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logoText {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--cherry);
  letter-spacing: -0.5px;
}

/* Бургер — скрыт на десктопе */
.burger {
  display: none;
  width: 40px;
  height: 40px;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--gray-700);
  border-radius: var(--radius-sm);
  transition: all var(--transition);
}

.burger:hover {
  background: var(--cherry-pale);
  color: var(--cherry);
}

/* Навигация десктоп */
.nav {
  display: flex;
  align-items: center;
  gap: 4px;
}

.navLink {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  font-size: 15px;
  font-weight: 500;
  color: var(--gray-700);
  border-radius: var(--radius-sm);
  transition: all var(--transition);
}

.navLink:hover {
  color: var(--cherry);
  background: var(--cherry-pale);
}

.navLink.active {
  color: var(--cherry);
  font-weight: 600;
}

.navLink.active::after {
  content: '';
  position: absolute;

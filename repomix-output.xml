  gap: 6px;
}

.statusBadge {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
}

.pending    { background: #FEF9C3; color: #A16207; }
.processing { background: #DBEAFE; color: #1D4ED8; }
.delivering { background: #D1FAE5; color: #065F46; }

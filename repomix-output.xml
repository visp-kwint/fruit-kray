<file path="frontend/src/pages/Profile/ProfilePage.module.css">
.page {
  padding: 40px 0 80px;
}

.loadingWrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.spinner {
  width: 48px;
  height: 48px;
  border: 4px solid var(--cherry-border);
  border-top-color: var(--cherry);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Шапка */
.profileHeader {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 40px;
}

.avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--cherry);
  color: white;
  font-size: 32px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(139, 26, 46, 0.3);
}

.profileName {
  font-size: 24px;
  font-weight: 700;
  color: var(--gray-900);
}

.profileRole {
  font-size: 14px;
  color: var(--gray-600);
  margin-top: 4px;
}

/* Вкладки */
.tabs {
  display: flex;
  gap: 4px;
  border-bottom: 2px solid var(--gray-200);
  margin-bottom: 40px;
}

.tab {
  padding: 12px 20px;
  font-size: 15px;
  font-weight: 500;
  color: var(--gray-600);
  background: transparent;
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  transition: all var(--transition);
  margin-bottom: -2px;
  border-bottom: 2px solid transparent;
}

.tab:hover {
  color: var(--cherry);
  background: var(--cherry-pale);
}

.activeTab {
  color: var(--cherry) !important;
  font-weight: 700;
  border-bottom-color: var(--cherry) !important;
  background: transparent !important;
}

.tabContent {
  animation: fade-in 0.2s ease;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.emptyTab {
  color: var(--gray-500);
  font-size: 15px;
  padding: 60px 0;
  text-align: center;
}

/* Карточка заказа */
.orderCard {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: 20px 24px;
  margin-bottom: 16px;
  transition: all var(--transition);
}

.orderCard:hover {
  border-color: var(--cherry-border);
  box-shadow: var(--shadow-sm);
}

.orderHeader {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.orderId {
  font-size: 17px;
  font-weight: 700;
  color: var(--gray-900);
}

.orderDate {
  font-size: 13px;
  color: var(--gray-500);
  margin-top: 4px;
}

.orderRight {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
}

.statusBadge {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
}

.pending    { background: #FEF9C3; color: #A16207; }
.processing { background: #DBEAFE; color: #1D4ED8; }
.delivering { background: #D1FAE5; color: #065F46; }
.done       { background: #F0FDF4; color: #166534; }
.cancelled  { background: #FEE2E2; color: #991B1B; }

.orderTotal {
  font-size: 18px;
  font-weight: 800;
  color: var(--cherry);
}

.orderItems {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.orderItem {
  padding: 4px 12px;
  background: var(--gray-100);
  border-radius: 20px;
  font-size: 13px;
  color: var(--gray-700);
}

.orderAddress {
  font-size: 13px;
  color: var(--gray-500);
}

/* Часто покупаемые */
.frequentGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.frequentCard {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  transition: all var(--transition);
  position: relative;
}

.frequentCard:hover {
  border-color: var(--cherry-border);
  box-shadow: var(--shadow-sm);
}

.frequentRank {
  position: absolute;
  top: -8px;
  left: -8px;
  width: 28px;
  height: 28px;
  background: var(--cherry);
  color: white;
  border-radius: 50%;
  font-size: 12px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.frequentImg {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  object-fit: cover;
  flex-shrink: 0;
}

.frequentInfo { flex: 1; }

.frequentName {
  font-size: 15px;
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 4px;
}

.frequentQty {
  font-size: 13px;
  color: var(--gray-600);
  margin-bottom: 4px;
}

.frequentPrice {
  font-size: 16px;
  font-weight: 800;
  color: var(--cherry);
}

/* Настройки */
.settingsForm {
  max-width: 480px;
}

.settingsTitle {
  font-family: var(--font-display);
  font-size: 22px;
  color: var(--gray-900);
  margin-bottom: 24px;
}

.field {
  margin-bottom: 20px;
}

.label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--gray-600);
  margin-bottom: 8px;
}

.input {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 15px;
  font-family: var(--font-main);
  outline: none;
  transition: border-color var(--transition);
}

.input:focus {
  border-color: var(--cherry);
  box-shadow: 0 0 0 3px rgba(139, 26, 46, 0.1);
}

.saveMsg {
  padding: 10px 16px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 16px;
}

.success {
  background: #F0FDF4;
  color: #166534;
  border: 1px solid #BBF7D0;
}

.error {
  background: #FEF2F2;
  color: #991B1B;
  border: 1px solid #FECACA;
}

<file path="frontend/src/pages/Profile/ProfilePage.module.css">
.page {
  padding: 40px 0 80px;
}

.loadingWrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.spinner {
  width: 48px;
  height: 48px;
  border: 4px solid var(--cherry-border);
  border-top-color: var(--cherry);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Шапка */
.profileHeader {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 40px;
}

.avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--cherry);
  color: white;
  font-size: 32px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(139, 26, 46, 0.3);
}

.profileName {
  font-size: 24px;
  font-weight: 700;
  color: var(--gray-900);
}

.profileRole {
  font-size: 14px;
  color: var(--gray-600);
  margin-top: 4px;
}

/* Вкладки */
.tabs {
  display: flex;
  gap: 4px;
  border-bottom: 2px solid var(--gray-200);
  margin-bottom: 40px;
}

.tab {
  padding: 12px 20px;

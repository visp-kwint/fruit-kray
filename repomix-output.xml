  font-size: 15px;
  background: #fff;
  outline: none;
  transition: border-color var(--transition);
}

.input:focus {
  border-color: var(--cherry);
  box-shadow: 0 0 0 3px rgba(139, 26, 46, 0.08);
}

/* Ряд с dropdown + цена */
.filterRow {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

/* ── Dropdown ───────────────────────────── */
.dropdown {
  position: relative;
  min-width: 180px;
}

.dropdownTrigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 14px;
  background: #fff;
  border: 1.5px solid var(--gray-200);
  border-radius: 12px;
  font-family: var(--font-main);
  font-size: 14px;
  font-weight: 500;
  color: var(--gray-900);
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}

.dropdownTrigger:hover {
  border-color: var(--cherry-border);
}

.dropdownTriggerOpen {
  border-color: var(--cherry);
  box-shadow: 0 0 0 3px rgba(139, 26, 46, 0.08);
}

.dropdownLabel {
  overflow: hidden;
  text-overflow: ellipsis;
}

.dropdownArrow {
  font-size: 12px;
  color: var(--gray-500);
  transition: transform var(--transition);
}

.dropdownTriggerOpen .dropdownArrow {
  transform: rotate(180deg);
}

.dropdownMenu {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  z-index: 50;
  min-width: 100%;
  max-height: 280px;
  overflow-y: auto;
  background: #fff;
  border: 1.5px solid var(--cherry-border);
  border-radius: 14px;
  box-shadow: var(--shadow-lg);
  padding: 6px;
  animation: dropdownIn 0.18s ease;
}

@keyframes dropdownIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.dropdownItem {
  width: 100%;
  text-align: left;
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--gray-800);
  background: transparent;
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}

.dropdownItem:hover {
  background: var(--cherry-pale);
  color: var(--cherry);
}

.dropdownItemActive {
  background: var(--cherry-pale);
  color: var(--cherry);
  font-weight: 700;
}

/* ── Цена ───────────────────────────────── */
.priceWrap {
  display: flex;
  align-items: center;
  gap: 8px;
}

.smallInput {
  width: 110px;
  padding: 10px 14px;

<file path="frontend/src/pages/Admin/AdminPage.module.css">
.page {
  padding: 40px 0 80px;
  background: var(--white);
}

.loadingWrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 4px solid var(--cherry-border);
  border-top-color: var(--cherry);
  animation: spin 0.85s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.adminHeader {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
  margin-bottom: 32px;
}

.adminTitle {
  font-family: var(--font-display);
  font-size: 34px;
  line-height: 1.1;
  color: var(--cherry);
  margin-bottom: 8px;
}

.adminSub {
  font-size: 15px;
  color: var(--gray-600);
}

.stats {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.statCard {
  min-width: 120px;
  padding: 16px 18px;
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #fff, var(--cherry-pale));
  border: 1px solid var(--cherry-border);
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.statNum {
  display: block;
  font-size: 28px;
  font-weight: 800;
  color: var(--cherry);
  line-height: 1;
}

.statLabel {
  display: block;
  margin-top: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--gray-600);
  text-transform: uppercase;
  letter-spacing: 0.6px;
}

/* ── Табы с бургером ─────────────────────────── */
.tabsWrap {
  position: relative;
  margin-bottom: 28px;
}

.burger {
  display: none;
  width: 40px;
  height: 40px;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--gray-700);
  border-radius: var(--radius-sm);
  transition: all var(--transition);
  margin-bottom: 12px;
}

.burger:hover {
  background: var(--cherry-pale);
  color: var(--cherry);
}

.tabs {
  display: flex;
  gap: 6px;
  border-bottom: 2px solid var(--gray-200);
  overflow-x: auto;
  padding-bottom: 2px;
}

.tab {
  padding: 12px 18px;
  border-radius: 14px 14px 0 0;
  background: transparent;
